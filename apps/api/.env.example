# Database - Local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/financeapp?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/financeapp?schema=public"

# JWT Secrets (generate your own for production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=another-super-secret-refresh-key-minimum-32-characters
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App Configuration
PORT=3001
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (optional for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="FinanceApp" <noreply@financeapp.com>
